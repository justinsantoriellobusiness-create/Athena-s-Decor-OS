{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest",
        "--executablePath=/opt/pw-browsers/chromium",
        "--headless",
        "--userDataDir=/tmp/claude-0/-home-user-Athena-s-Decor-OS/105480b6-0f10-5098-b641-b08ce42b0f00/scratchpad/chrome-profile",
        "--chromeArg=--no-sandbox",
        "--chromeArg=--disable-setuid-sandbox",
        "--chromeArg=--disable-dev-shm-usage",
        "--chromeArg=--disable-gpu",
        "--logFile=/tmp/claude-0/-home-user-Athena-s-Decor-OS/105480b6-0f10-5098-b641-b08ce42b0f00/scratchpad/chrome-devtools-mcp.log"
      ],
      "env": {}
    },
    "railway": {
      "type": "http",
      "url": "https://mcp.railway.com"
    },
    "firecrawl": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    }
  }
}
